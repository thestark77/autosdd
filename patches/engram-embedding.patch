+func TestEmbeddingCosineSimilarity(t *testing.T) {
+	a := []float64{1, 0, 0}
+	b := []float64{1, 0, 0}
+	if s := embeddingCosineSimilarity(a, b); math.Abs(s-1.0) > 1e-9 {
