+++ b/internal/embedding/provider.go
@@ -0,0 +1,26 @@
+package embedding
+
+// Provider generates vector embeddings from text.
+type Provider interface {
+	Embed(text string) ([]float64, error)
+	EmbedBatch(texts []string) ([][]float64, error)
+	Dimensions() int
+	Name() string
+}
+
+// Config for the embedding system.
+type Config struct {
+	Provider string // "local" (default) or "api"
+	APIKey   string
+	APIURL   string // default: "https://openrouter.ai/api/v1/embeddings"
+	APIModel string // default: "openai/text-embedding-3-small"
+}
+
+// DefaultConfig returns config with local provider as default.
+func DefaultConfig() Config {
+	return Config{
+		Provider: "local",
+		APIURL:   "https://openrouter.ai/api/v1/embeddings",
+		APIModel: "openai/text-embedding-3-small",
+	}
+}
