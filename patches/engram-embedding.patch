+
+func TestSerializeDeserializeEmbedding(t *testing.T) {
+	original := []float64{0.1, 0.2, 0.3, -0.5, 1.0}
+	blob := serializeEmbedding(original)
+	restored := deserializeEmbedding(blob, len(original))
+
+	for i := range original {
+		if math.Abs(original[i]-restored[i]) > 1e-15 {
+			t.Errorf("index %d: want %f, got %f", i, original[i], restored[i])
+		}
+	}
+}
+
+func TestSerializeEmbeddingSize(t *testing.T) {
+	vec := make([]float64, 384)
+	blob := serializeEmbedding(vec)
+	if len(blob) != 384*8 {
+		t.Errorf("blob size: want %d, got %d", 384*8, len(blob))
+	}
+}
+
+func TestSaveAndSearchEmbedding(t *testing.T) {
+	s := newTestStore(t)
+
+	if err := s.CreateSession("s1", "test", "/tmp/test"); err != nil {
+		t.Fatalf("create session: %v", err)
+	}
+
+	// Save three observations with different embeddings
+	id1, _ := s.AddObservation(AddObservationParams{
+		SessionID: "s1", Type: "decision", Title: "Auth design",
+		Content: "Use JWT for authentication", Project: "test",
+	})
+	id2, _ := s.AddObservation(AddObservationParams{
+		SessionID: "s1", Type: "decision", Title: "Login flow",
+		Content: "OAuth2 login flow implementation", Project: "test",
+	})
+	id3, _ := s.AddObservation(AddObservationParams{
+		SessionID: "s1", Type: "decision", Title: "Cake recipe",
+		Content: "Chocolate cake with frosting", Project: "test",
+	})
+
+	// Create embeddings: auth and login are similar, cake is different
+	vecAuth := make([]float64, 10)
+	vecAuth[0] = 0.9
+	vecAuth[1] = 0.8
+	vecAuth[2] = 0.1
+
+	vecLogin := make([]float64, 10)
+	vecLogin[0] = 0.85
+	vecLogin[1] = 0.75
+	vecLogin[2] = 0.15
+
+	vecCake := make([]float64, 10)
+	vecCake[5] = 0.9
+	vecCake[6] = 0.8
+	vecCake[7] = 0.7
+
+	if err := s.SaveEmbedding(id1, vecAuth, "local"); err != nil {
+		t.Fatalf("save embedding 1: %v", err)
+	}
+	if err := s.SaveEmbedding(id2, vecLogin, "local"); err != nil {
+		t.Fatalf("save embedding 2: %v", err)
+	}
+	if err := s.SaveEmbedding(id3, vecCake, "local"); err != nil {
+		t.Fatalf("save embedding 3: %v", err)
+	}
+
+	// Search with a query vector similar to auth/login
+	queryVec := make([]float64, 10)
+	queryVec[0] = 0.88
+	queryVec[1] = 0.77
+	queryVec[2] = 0.12
+
+	results, err := s.SearchByEmbedding(queryVec, SearchOptions{
+		Project: "test",
+		Limit:   10,
+	})
+	if err != nil {
+		t.Fatalf("search by embedding: %v", err)
+	}
+
+	if len(results) != 3 {
+		t.Fatalf("expected 3 results, got %d", len(results))
+	}
+
+	// Auth and Login should rank higher than Cake
+	if results[0].Title != "Auth design" && results[0].Title != "Login flow" {
+		t.Errorf("top result should be auth or login, got %q", results[0].Title)
+	}
+	if results[2].Title != "Cake recipe" {
+		t.Errorf("last result should be cake, got %q", results[2].Title)
+	}
+}
+
+func TestSaveEmbeddingUpsert(t *testing.T) {
+	s := newTestStore(t)
+
+	if err := s.CreateSession("s1", "test", "/tmp/test"); err != nil {
+		t.Fatalf("create session: %v", err)
+	}
+
+	id, _ := s.AddObservation(AddObservationParams{
+		SessionID: "s1", Type: "decision", Title: "Test",
+		Content: "test content", Project: "test",
+	})
+
+	vec1 := []float64{0.1, 0.2, 0.3}
+	vec2 := []float64{0.4, 0.5, 0.6}
+
+	if err := s.SaveEmbedding(id, vec1, "local"); err != nil {
+		t.Fatalf("first save: %v", err)
+	}
+	if err := s.SaveEmbedding(id, vec2, "local"); err != nil {
+		t.Fatalf("upsert: %v", err)
+	}
+
+	// Search should find only one result (not duplicated)
+	results, err := s.SearchByEmbedding(vec2, SearchOptions{Project: "test", Limit: 10})
+	if err != nil {
+		t.Fatalf("search: %v", err)
+	}
+
+	count := 0
+	for _, r := range results {
+		if r.ID == id {
+			count++
+		}
+	}
+	if count != 1 {
+		t.Errorf("expected 1 result for upserted ID, got %d", count)
+	}
+}
+
+func TestDeleteEmbedding(t *testing.T) {
+	s := newTestStore(t)
+
+	if err := s.CreateSession("s1", "test", "/tmp/test"); err != nil {
+		t.Fatalf("create session: %v", err)
+	}
+
+	id, _ := s.AddObservation(AddObservationParams{
+		SessionID: "s1", Type: "decision", Title: "Test",
+		Content: "test content", Project: "test",
+	})
+
+	vec := []float64{0.1, 0.2, 0.3}
+	if err := s.SaveEmbedding(id, vec, "local"); err != nil {
+		t.Fatalf("save: %v", err)
+	}
+
+	if err := s.DeleteEmbedding(id); err != nil {
+		t.Fatalf("delete: %v", err)
+	}
+
+	results, err := s.SearchByEmbedding(vec, SearchOptions{Project: "test", Limit: 10})
+	if err != nil {
+		t.Fatalf("search after delete: %v", err)
+	}
+
+	for _, r := range results {
+		if r.ID == id {
+			t.Error("deleted embedding should not appear in results")
+		}
+	}
+}
+
+func TestSearchByEmbeddingRespectsDeletedObservations(t *testing.T) {
+	s := newTestStore(t)
+
+	if err := s.CreateSession("s1", "test", "/tmp/test"); err != nil {
+		t.Fatalf("create session: %v", err)
+	}
+
+	id, _ := s.AddObservation(AddObservationParams{
+		SessionID: "s1", Type: "decision", Title: "Test",
+		Content: "test content", Project: "test",
+	})
+
+	vec := []float64{0.1, 0.2, 0.3}
+	if err := s.SaveEmbedding(id, vec, "local"); err != nil {
