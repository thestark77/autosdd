diff --git a/internal/embedding/local.go b/internal/embedding/local.go
new file mode 100644
index 0000000..2f447d5
--- /dev/null
+++ b/internal/embedding/local.go
@@ -0,0 +1,90 @@
+package embedding
+
+import (
+	"hash/fnv"
+	"math"
+	"strings"
+	"unicode"
+)
+
+const localDims = 384
+
+// LocalProvider uses TF-IDF hashing vectorizer for lightweight local embeddings.
+// Not true semantic search, but handles partial matches, word order variations,
+// and substring-like matching that FTS5 misses. Zero external dependencies.
+type LocalProvider struct{}
+
+// NewLocalProvider creates a local embedding provider.
+func NewLocalProvider() *LocalProvider {
+	return &LocalProvider{}
+}
+
+func (p *LocalProvider) Name() string    { return "local" }
+func (p *LocalProvider) Dimensions() int { return localDims }
+
+func (p *LocalProvider) Embed(text string) ([]float64, error) {
+	tokens := tokenize(text)
+	ngrams := generateNgrams(tokens, 2)
+
+	vec := make([]float64, localDims)
+	for _, ng := range ngrams {
+		idx := hashToIndex(ng, localDims)
+		vec[idx] += 1.0
+	}
+
+	l2Normalize(vec)
+	return vec, nil
+}
+
+func (p *LocalProvider) EmbedBatch(texts []string) ([][]float64, error) {
+	results := make([][]float64, len(texts))
+	for i, t := range texts {
+		v, err := p.Embed(t)
+		if err != nil {
+			return nil, err
+		}
+		results[i] = v
+	}
+	return results, nil
+}
+
+func tokenize(text string) []string {
+	lower := strings.ToLower(text)
+	words := strings.FieldsFunc(lower, func(r rune) bool {
+		return !unicode.IsLetter(r) && !unicode.IsDigit(r)
+	})
+	return words
+}
+
+func generateNgrams(tokens []string, maxN int) []string {
+	var ngrams []string
+	for _, t := range tokens {
+		ngrams = append(ngrams, t)
+	}
+	if maxN >= 2 {
+		for i := 0; i < len(tokens)-1; i++ {
+			ngrams = append(ngrams, tokens[i]+"_"+tokens[i+1])
+		}
+	}
+	return ngrams
+}
+
+func hashToIndex(s string, dims int) int {
+	h := fnv.New32a()
+	h.Write([]byte(s))
+	return int(h.Sum32()) % dims
+}
+
+func l2Normalize(vec []float64) {
+	var sum float64
+	for _, v := range vec {
+		sum += v * v
+	}
+	if sum == 0 {
+		return
+	}
+	norm := math.Sqrt(sum)
+	for i := range vec {
+		vec[i] /= norm
+	}
+}
diff --git a/internal/embedding/local_test.go b/internal/embedding/local_test.go
new file mode 100644
