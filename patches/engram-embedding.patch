diff --git a/internal/embedding/api.go b/internal/embedding/api.go
new file mode 100644
index 0000000..21b9762
--- /dev/null
+++ b/internal/embedding/api.go
@@ -0,0 +1,124 @@
+package embedding
+
+import (
+	"bytes"
+	"encoding/json"
+	"fmt"
+	"io"
+	"net/http"
+	"time"
+)
+
+type embedRequest struct {
+	Model string   `json:"model"`
+	Input []string `json:"input"`
+}
+
+type embedResponse struct {
+	Data []struct {
+		Embedding []float64 `json:"embedding"`
+		Index     int       `json:"index"`
+	} `json:"data"`
+	Error *struct {
+		Message string `json:"message"`
+	} `json:"error,omitempty"`
+}
+
+// APIProvider calls an OpenAI-compatible embedding API (OpenRouter, OpenAI, etc).
+type APIProvider struct {
+	apiKey string
+	apiURL string
+	model  string
+	dims   int
+	client *http.Client
+}
+
+// NewAPIProvider creates an API-based embedding provider.
+func NewAPIProvider(apiKey, apiURL, model string) *APIProvider {
+	if apiURL == "" {
+		apiURL = "https://openrouter.ai/api/v1/embeddings"
+	}
+	if model == "" {
+		model = "openai/text-embedding-3-small"
+	}
+	return &APIProvider{
+		apiKey: apiKey,
+		apiURL: apiURL,
+		model:  model,
+		dims:   0,
+		client: &http.Client{Timeout: 30 * time.Second},
+	}
+}
+
+func (p *APIProvider) Name() string { return "api" }
+
+func (p *APIProvider) Dimensions() int {
+	if p.dims > 0 {
+		return p.dims
+	}
+	return 1536
+}
+
+func (p *APIProvider) Embed(text string) ([]float64, error) {
+	vecs, err := p.EmbedBatch([]string{text})
+	if err != nil {
+		return nil, err
+	}
+	return vecs[0], nil
+}
+
+func (p *APIProvider) EmbedBatch(texts []string) ([][]float64, error) {
+	body, err := json.Marshal(embedRequest{
+		Model: p.model,
+		Input: texts,
+	})
+	if err != nil {
+		return nil, fmt.Errorf("embedding api: marshal request: %w", err)
+	}
+
+	req, err := http.NewRequest("POST", p.apiURL, bytes.NewReader(body))
+	if err != nil {
+		return nil, fmt.Errorf("embedding api: create request: %w", err)
+	}
+	req.Header.Set("Content-Type", "application/json")
+	req.Header.Set("Authorization", "Bearer "+p.apiKey)
+
+	resp, err := p.client.Do(req)
+	if err != nil {
+		return nil, fmt.Errorf("embedding api: request failed: %w", err)
+	}
+	defer resp.Body.Close()
+
+	respBody, err := io.ReadAll(resp.Body)
+	if err != nil {
+		return nil, fmt.Errorf("embedding api: read response: %w", err)
+	}
+
+	if resp.StatusCode != http.StatusOK {
+		return nil, fmt.Errorf("embedding api: status %d: %s", resp.StatusCode, string(respBody))
+	}
+
+	var result embedResponse
+	if err := json.Unmarshal(respBody, &result); err != nil {
+		return nil, fmt.Errorf("embedding api: parse response: %w", err)
+	}
+
+	if result.Error != nil {
+		return nil, fmt.Errorf("embedding api: %s", result.Error.Message)
+	}
+
+	if len(result.Data) != len(texts) {
+		return nil, fmt.Errorf("embedding api: expected %d embeddings, got %d", len(texts), len(result.Data))
+	}
+
+	vecs := make([][]float64, len(texts))
+	for _, d := range result.Data {
+		vecs[d.Index] = d.Embedding
+	}
+
+	if len(vecs) > 0 && len(vecs[0]) > 0 {
+		p.dims = len(vecs[0])
+	}
+
+	return vecs, nil
+}
