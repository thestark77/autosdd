+// ─── Embedding Storage ──────────────────────────────────────────────────────
+
+// SaveEmbedding stores a vector embedding for an observation (upsert).
+func (s *Store) SaveEmbedding(observationID int64, embedding []float64, provider string) error {
+	blob := serializeEmbedding(embedding)
+	_, err := s.execHook(s.db,
+		`INSERT INTO observation_embeddings (observation_id, embedding, dimensions, provider, created_at)
+		 VALUES (?, ?, ?, ?, datetime('now'))
+		 ON CONFLICT(observation_id) DO UPDATE SET
+		     embedding = excluded.embedding,
+		     dimensions = excluded.dimensions,
+		     provider = excluded.provider,
+		     created_at = datetime('now')`,
+		observationID, blob, len(embedding), provider,
+	)
+	if err != nil {
+		return fmt.Errorf("save embedding: %w", err)
+	}
+	return nil
+}
+
+// SearchByEmbedding finds observations similar to the given vector using cosine similarity.
+func (s *Store) SearchByEmbedding(queryEmbedding []float64, opts SearchOptions) ([]SearchResult, error) {
+	opts.Project, _ = NormalizeProject(opts.Project)
+
+	limit := opts.Limit
+	if limit <= 0 {
+		limit = 10
+	}
+	if limit > s.cfg.MaxSearchResults {
+		limit = s.cfg.MaxSearchResults
+	}
+
+	sqlQ := `
+		SELECT e.observation_id, e.embedding, e.dimensions,
+		       o.id, ifnull(o.sync_id, '') as sync_id, o.session_id, o.type, o.title, o.content,
+		       o.tool_name, o.project, o.scope, o.topic_key, o.revision_count, o.duplicate_count,
+		       o.last_seen_at, o.created_at, o.updated_at, o.deleted_at
+		FROM observation_embeddings e
+		JOIN observations o ON o.id = e.observation_id
+		WHERE o.deleted_at IS NULL
+	`
+	args := []any{}
+
+	if opts.Type != "" {
+		sqlQ += " AND o.type = ?"
+		args = append(args, opts.Type)
+	}
+	if opts.Project != "" {
+		sqlQ += " AND o.project = ?"
+		args = append(args, opts.Project)
+	}
+	if opts.Scope != "" {
+		sqlQ += " AND o.scope = ?"
+		args = append(args, normalizeScope(opts.Scope))
+	}
+
+	rows, err := s.queryItHook(s.db, sqlQ, args...)
+	if err != nil {
+		return nil, fmt.Errorf("search by embedding: %w", err)
+	}
+	defer rows.Close()
+
+	type scored struct {
+		result SearchResult
+		score  float64
+	}
+	var candidates []scored
+
+	for rows.Next() {
+		var (
+			embID int64
+			blob  []byte
+			dims  int
+			sr    SearchResult
+		)
+		if err := rows.Scan(
+			&embID, &blob, &dims,
+			&sr.ID, &sr.SyncID, &sr.SessionID, &sr.Type, &sr.Title, &sr.Content,
+			&sr.ToolName, &sr.Project, &sr.Scope, &sr.TopicKey, &sr.RevisionCount, &sr.DuplicateCount,
+			&sr.LastSeenAt, &sr.CreatedAt, &sr.UpdatedAt, &sr.DeletedAt,
+		); err != nil {
+			return nil, err
+		}
+
+		storedVec := deserializeEmbedding(blob, dims)
+		score := embeddingCosineSimilarity(queryEmbedding, storedVec)
+		sr.Rank = -score // negative so higher similarity = more negative = "better" rank (FTS5 convention)
+		candidates = append(candidates, scored{result: sr, score: score})
+	}
+	if err := rows.Err(); err != nil {
+		return nil, err
+	}
+
+	sort.Slice(candidates, func(i, j int) bool {
+		return candidates[i].score > candidates[j].score
+	})
+
+	if len(candidates) > limit {
+		candidates = candidates[:limit]
+	}
+
+	results := make([]SearchResult, len(candidates))
+	for i, c := range candidates {
+		results[i] = c.result
+	}
+	return results, nil
+}
+
+// DeleteEmbedding removes the embedding for an observation.
+func (s *Store) DeleteEmbedding(observationID int64) error {
+	_, err := s.execHook(s.db,
+		`DELETE FROM observation_embeddings WHERE observation_id = ?`,
+		observationID,
+	)
+	if err != nil {
+		return fmt.Errorf("delete embedding: %w", err)
+	}
+	return nil
+}
+
+func serializeEmbedding(embedding []float64) []byte {
+	buf := make([]byte, len(embedding)*8)
+	for i, v := range embedding {
+		binary.LittleEndian.PutUint64(buf[i*8:], math.Float64bits(v))
+	}
+	return buf
+}
+
+func deserializeEmbedding(data []byte, dims int) []float64 {
+	vec := make([]float64, dims)
+	for i := 0; i < dims && i*8+8 <= len(data); i++ {
+		vec[i] = math.Float64frombits(binary.LittleEndian.Uint64(data[i*8:]))
+	}
+	return vec
+}
+
+func embeddingCosineSimilarity(a, b []float64) float64 {
+	if len(a) != len(b) || len(a) == 0 {
+		return 0
+	}
+	var dot, normA, normB float64
+	for i := range a {
+		dot += a[i] * b[i]
+		normA += a[i] * a[i]
+		normB += b[i] * b[i]
+	}
+	if normA == 0 || normB == 0 {
+		return 0
+	}
+	return dot / (math.Sqrt(normA) * math.Sqrt(normB))
+}
