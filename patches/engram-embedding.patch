@@ -0,0 +1,107 @@
+package embedding
+
+import (
+	"math"
+	"testing"
+)
+
+func TestLocalProviderEmbed(t *testing.T) {
+	p := NewLocalProvider()
+
+	vec, err := p.Embed("hello world")
+	if err != nil {
+		t.Fatalf("Embed: %v", err)
+	}
+
+	if len(vec) != 384 {
+		t.Errorf("dimensions: want 384, got %d", len(vec))
+	}
+
+	// Vector should be L2-normalized (magnitude ≈ 1.0)
+	var mag float64
+	for _, v := range vec {
+		mag += v * v
+	}
+	mag = math.Sqrt(mag)
+	if math.Abs(mag-1.0) > 1e-9 {
+		t.Errorf("magnitude: want 1.0, got %f", mag)
+	}
+}
+
+func TestLocalProviderDeterministic(t *testing.T) {
+	p := NewLocalProvider()
+	v1, _ := p.Embed("test input")
+	v2, _ := p.Embed("test input")
+
+	for i := range v1 {
+		if v1[i] != v2[i] {
+			t.Fatalf("not deterministic at index %d: %f != %f", i, v1[i], v2[i])
+		}
+	}
+}
+
+func TestLocalProviderSimilarTexts(t *testing.T) {
+	p := NewLocalProvider()
+	v1, _ := p.Embed("fix authentication bug in login")
+	v2, _ := p.Embed("fix login bug in authentication")
+	v3, _ := p.Embed("recipe for chocolate cake")
+
+	sim12 := CosineSimilarity(v1, v2)
+	sim13 := CosineSimilarity(v1, v3)
+
+	if sim12 <= sim13 {
+		t.Errorf("similar texts should have higher similarity: sim(auth,login)=%f <= sim(auth,cake)=%f", sim12, sim13)
+	}
+}
+
+func TestLocalProviderEmbedBatch(t *testing.T) {
+	p := NewLocalProvider()
+	texts := []string{"hello", "world", "test"}
+
+	vecs, err := p.EmbedBatch(texts)
+	if err != nil {
+		t.Fatalf("EmbedBatch: %v", err)
+	}
+
+	if len(vecs) != 3 {
+		t.Errorf("batch size: want 3, got %d", len(vecs))
+	}
+
+	for i, v := range vecs {
+		single, _ := p.Embed(texts[i])
+		if CosineSimilarity(v, single) < 0.999 {
+			t.Errorf("batch result %d differs from single embed", i)
+		}
+	}
+}
+
+func TestLocalProviderEmptyText(t *testing.T) {
+	p := NewLocalProvider()
+	vec, err := p.Embed("")
+	if err != nil {
+		t.Fatalf("Embed empty: %v", err)
+	}
+
+	// Empty text produces zero vector (all zeros) — magnitude is 0
+	var mag float64
+	for _, v := range vec {
+		mag += v * v
+	}
+	if mag != 0 {
+		t.Errorf("empty text should produce zero vector, got magnitude %f", math.Sqrt(mag))
+	}
+}
+
+func TestLocalProviderName(t *testing.T) {
+	p := NewLocalProvider()
+	if p.Name() != "local" {
+		t.Errorf("Name: want 'local', got %q", p.Name())
+	}
+}
+
+func TestLocalProviderDimensions(t *testing.T) {
+	p := NewLocalProvider()
+	if p.Dimensions() != 384 {
+		t.Errorf("Dimensions: want 384, got %d", p.Dimensions())
+	}
+}
diff --git a/internal/embedding/provider.go b/internal/embedding/provider.go
