+++ b/internal/embedding/factory.go
@@ -0,0 +1,19 @@
+package embedding
+
+import "fmt"
+
+// NewProvider creates an embedding provider based on config.
+// Defaults to local provider if no provider is specified.
+func NewProvider(cfg Config) (Provider, error) {
+	switch cfg.Provider {
+	case "api":
+		if cfg.APIKey == "" {
+			return nil, fmt.Errorf("embedding: API key required for api provider")
+		}
+		return NewAPIProvider(cfg.APIKey, cfg.APIURL, cfg.APIModel), nil
+	case "local", "":
+		return NewLocalProvider(), nil
+	default:
+		return nil, fmt.Errorf("embedding: unknown provider %q", cfg.Provider)
+	}
+}
