+package embedding
+
+import (
+	"os"
+	"testing"
+)
+
+// TODO: Remove hardcoded API key before production. User must set ENGRAM_EMBEDDING_API_KEY env var.
+func getTestAPIKey(t *testing.T) string {
+	key := os.Getenv("ENGRAM_EMBEDDING_API_KEY")
+	if key == "" {
+		t.Skip("ENGRAM_EMBEDDING_API_KEY not set, skipping API test")
+	}
+	return key
+}
+
+func TestAPIProviderEmbed(t *testing.T) {
+	key := getTestAPIKey(t)
+	p := NewAPIProvider(key, "https://openrouter.ai/api/v1/embeddings", "openai/text-embedding-3-small")
+
+	vec, err := p.Embed("hello world")
+	if err != nil {
+		t.Fatalf("Embed: %v", err)
+	}
+
+	if len(vec) == 0 {
+		t.Fatal("empty embedding returned")
+	}
+
+	t.Logf("API returned %d dimensions", len(vec))
+}
+
+func TestAPIProviderEmbedBatch(t *testing.T) {
+	key := getTestAPIKey(t)
+	p := NewAPIProvider(key, "https://openrouter.ai/api/v1/embeddings", "openai/text-embedding-3-small")
+
+	vecs, err := p.EmbedBatch([]string{"hello", "world"})
+	if err != nil {
+		t.Fatalf("EmbedBatch: %v", err)
+	}
+
+	if len(vecs) != 2 {
+		t.Errorf("batch size: want 2, got %d", len(vecs))
+	}
+
+	if len(vecs[0]) != len(vecs[1]) {
+		t.Errorf("dimension mismatch: %d vs %d", len(vecs[0]), len(vecs[1]))
+	}
+}
+
+func TestAPIProviderSemanticSimilarity(t *testing.T) {
+	key := getTestAPIKey(t)
+	p := NewAPIProvider(key, "https://openrouter.ai/api/v1/embeddings", "openai/text-embedding-3-small")
+
+	vecs, err := p.EmbedBatch([]string{
+		"authentication login user sign-in",
+		"user sign-in authentication flow",
+		"chocolate cake recipe baking",
+	})
+	if err != nil {
+		t.Fatalf("EmbedBatch: %v", err)
+	}
+
+	simSimilar := CosineSimilarity(vecs[0], vecs[1])
+	simDifferent := CosineSimilarity(vecs[0], vecs[2])
+
+	t.Logf("similar: %f, different: %f", simSimilar, simDifferent)
+
+	if simSimilar <= simDifferent {
+		t.Errorf("semantically similar texts should have higher similarity: %f <= %f", simSimilar, simDifferent)
+	}
+}
+
+func TestAPIProviderName(t *testing.T) {
+	p := NewAPIProvider("key", "", "")
+	if p.Name() != "api" {
+		t.Errorf("Name: want 'api', got %q", p.Name())
+	}
+}
+
+func TestAPIProviderNoKey(t *testing.T) {
+	_, err := NewProvider(Config{Provider: "api"})
+	if err == nil {
+		t.Error("expected error for api provider without key")
+	}
+}
